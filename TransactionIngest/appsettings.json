{
  "ConnectionStrings": {
    "Default": "Data Source=transactions.db"
  },
  "Api": {
    "BaseUrl": "https://payments.example.com",
    "SnapshotPath": "/api/transactions/snapshot"
  },
  "MockFeed": {
    "Enabled": true,
    "FilePath": "mock_feed.json"
  },
  "Ingestion": {
    "WindowHours": 24
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
